---
// Marquee band "A NOVA ERA DO TREINO INTELIGENTE" + technologies grid (light gray band)
const techs = [
  { title: 'WEVOL EMS', image: 'images/tech-ems.png' },
  { title: 'Estação Inteligente', image: 'images/tech-estacao.png' },
  { title: 'M30', image: 'images/tech-m30.png' },
  { title: 'S-Drive', image: 'images/tech-sdrive.png' },
  { title: 'NeuroSculpt', image: 'images/tech-m30.png' },
  { title: 'BioTriagem', image: 'images/tech-biotriagem.png' },
  { title: 'InfraSpa', image: 'images/tech-infraspa.png' },
  { title: 'Creator 600', image: 'images/tech-ems.png' },
];
const pill = 'A NOVA ERA DO TREINO INTELIGENTE';
---

<section class="relative bg-wevol-light">
  {/* tagline pill straddling the black → gray boundary (Figma: #111, Sans Medium) */}
  <div class="relative flex -translate-y-1/2 justify-center px-6">
    <div class="flex items-center justify-center rounded-full bg-[#111] px-8 py-6 lg:px-16 lg:py-10">
      <p class="whitespace-nowrap text-center text-[11px] font-medium uppercase leading-5 tracking-[0.2em] text-wevol-off-white sm:text-sm sm:tracking-[0.5em]">
        {pill}
      </p>
    </div>
  </div>

  <img
    src="icons/decor-tech.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute bottom-0 left-0 hidden max-h-[70%] xl:block"
  />

  <div class="wv-container relative pb-24 pt-10">
    <h2
      class="wv-title wv-ftype [--fs-min:36] [--fs-max:48] mx-auto max-w-[808px] text-center leading-tight text-wevol-ink"
      data-reveal="words"
    >
      A inteligência por trás da sua evolução.
    </h2>

    <div class="mt-24 grid grid-cols-2 gap-3 md:grid-cols-4 xl:gap-6">
      {techs.map((tech) => (
        <a
          href="#"
          class="group relative flex aspect-square flex-col justify-end overflow-hidden rounded p-4 focus-visible:outline-2 focus-visible:outline-wevol-orange xl:aspect-[286/320] xl:p-5"
        >
          <img
            src={tech.image}
            alt={tech.title}
            class="absolute inset-0 size-full object-cover transition-transform duration-500 group-hover:scale-105"
            data-reveal-img
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 to-black/0 to-50%"
            aria-hidden="true"
          ></div>
          <h3 class="wv-title relative text-lg leading-[1.25] tracking-[-0.02em] text-white sm:text-xl xl:text-2xl">
            {tech.title}
          </h3>
        </a>
      ))}
    </div>

    <div class="mt-16 flex justify-center">
      <a href="#" class="wv-btn-primary">Conheça todas as tecnologias</a>
    </div>
  </div>
</section>
