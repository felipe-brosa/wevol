---
// Blog cards (placeholder copy from Figma; distinct title/image per card) + CTA.
const resumo =
  'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aliquam non luctus justo. Donec pharetra magna sapien, nec lacinia turpis interdum eu. Pellentesque habitant morbi tristique senectus ...';
const posts = [
  { titulo: 'O que é biohacking e como funciona', imagem: 'images/tech-biotriagem.png', resumo },
  {
    titulo: 'Como melhorar a performance física com tecnologia',
    imagem: 'images/tech-ems.png',
    resumo,
  },
  {
    titulo: 'Longevidade: hábitos e tecnologias para viver melhor',
    imagem: 'images/tech-estacao.png',
    resumo,
  },
];
---

<section class="relative overflow-hidden bg-wevol-black py-24">
  <img
    src="icons/decor-blog.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -top-24 right-0 hidden max-w-[40%] xl:block"
  />

  <div class="wv-container relative">
    <h2
      class="wv-title-alt text-center text-6xl leading-none tracking-[-0.02em] text-wevol-off-white"
      data-reveal="words"
    >
      Conteúdo para evoluir todos os dias
    </h2>

    <div class="mt-20 grid grid-cols-1 gap-x-10 gap-y-14 md:grid-cols-2 md:gap-y-10 xl:grid-cols-3">
      {posts.map((post) => (
        <a href="#" class="group flex flex-col gap-6 focus-visible:outline-2 focus-visible:outline-wevol-orange">
          <span class="block h-[320px] overflow-hidden rounded">
            <img
              src={post.imagem}
              alt=""
              class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
              data-reveal-img
            />
          </span>
          <span class="flex flex-col gap-3 text-wevol-off-white">
            <span class="wv-title text-2xl leading-[1.25] tracking-[-0.02em] transition-colors group-hover:text-wevol-grad-1">
              {post.titulo}
            </span>
            <span class="text-base">{post.resumo}</span>
            <span class="mt-1 inline-flex w-fit items-center gap-1 border-b border-wevol-grad-1 pb-1 text-base font-medium leading-6 text-wevol-grad-1">
              Ler matéria completa no blog
              <svg width="24" height="13" viewBox="0 0 24 13" fill="none" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">
                <path d="M0 6.5h22M16.5 1 22 6.5 16.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </span>
        </a>
      ))}
    </div>

    <div class="mt-24 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-8">
      <p class="text-base text-wevol-off-white" data-reveal="lines">
        Veja mais dicas e conteúdos em nosso blog
      </p>
      <a href="#" class="wv-btn-primary" data-label="Ver o blog">Ver o blog</a>
    </div>
  </div>
</section>
