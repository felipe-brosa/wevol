---

---

<section class="relative flex min-h-svh items-end overflow-hidden bg-wevol-black">
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src="images/hero-bg.png"
      alt=""
      class="size-full object-cover"
      data-reveal-img
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(0deg, rgb(9, 9, 9) 0%, rgba(17, 17, 17, 0) 56.348%), linear-gradient(90deg, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.1) 100%);"
    >
    </div>
  </div>

  <div class="wv-container relative pb-8 pt-40">
    <div class="flex max-w-[1065px] flex-col gap-8 text-wevol-off-white">
      <h1 class="wv-title text-[clamp(56px,6.67vw,128px)] tracking-[-0.02em]" data-reveal="words">
        Evolução da saúde<br />e performance
      </h1>
      <p class="wv-title-alt max-w-[800px] text-[clamp(20px,1.57vw,30px)]" data-reveal="lines">
        Muito mais do que um treino. A WEVOL integra tecnologia, inteligência e acompanhamento
        personalizado para criar uma experiência única de evolução humana.
      </p>
    </div>
  </div>
</section>
