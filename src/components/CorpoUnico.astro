        class="mx-auto w-full max-w-[976px] object-contain xl:absolute xl:left-[calc(50%+340px)] xl:top-1/2 xl:w-[696px] xl:max-w-none xl:-translate-x-1/2 xl:-translate-y-1/2 2xl:w-[928px]"
        data-reveal-img
      />
    </div>
  </div>
