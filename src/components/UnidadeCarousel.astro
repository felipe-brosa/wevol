---
// Full-width unit showcase (85vh) with crossfading slides.
// Desktop (lg+): thumbnail selector overlay. Mobile: swipe/drag to change
// slides — the switch is a fade (not a dragged carousel).
const slides = [
  'images/unidade-store.png',
  'images/unidade-thumb-1.png',
  'images/unidade-thumb-2.png',
  'images/unidade-thumb-1.png',
  'images/unidade-thumb-2.png',
];
---

<section class="bg-wevol-black px-8" data-unidade>
  <div class="relative h-[85vh] overflow-hidden rounded-lg" data-unidade-stage>
    {/* Stacked slides — only the active one is visible; changes crossfade */}
    {slides.map((src, i) => (
      <img
        src={src}
        alt="Unidade WEVOL"
        class="absolute inset-0 size-full object-cover transition-opacity duration-500 ease-out"
        style={`opacity:${i === 0 ? 1 : 0}`}
        data-unidade-slide={i}
        draggable="false"
      />
    ))}

    <div
      class="absolute bottom-6 left-1/2 hidden w-[min(1048px,90%)] -translate-x-1/2 gap-2 rounded bg-wevol-beige p-2 lg:flex xl:bottom-10"
    >
      {slides.map((src, i) => (
        <button
          type="button"
          class="group relative aspect-[600/400] min-w-0 flex-1 cursor-pointer overflow-hidden rounded focus-visible:outline-2 focus-visible:outline-wevol-orange"
          aria-label={`Ver foto ${i + 1} da unidade`}
          data-unidade-idx={i}
          data-unidade-thumb={i === 0 ? 'active' : ''}
        >
          <img src={src} alt="" class="size-full object-cover transition-transform duration-300 group-hover:scale-105" />
          <span
            class="absolute inset-0 rounded bg-black/65 opacity-0 transition-opacity duration-300 [[data-unidade-thumb='active']_&]:opacity-100"
            aria-hidden="true"
          ></span>
        </button>
      ))}
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-unidade]');
  if (root) {
    const stage = root.querySelector<HTMLElement>('[data-unidade-stage]')!;
    const slides = [...root.querySelectorAll<HTMLElement>('[data-unidade-slide]')];
    const thumbs = [...root.querySelectorAll<HTMLButtonElement>('[data-unidade-thumb]')];
    const N = slides.length;
    let current = 0;

    // Crossfade to slide i (wraps around).
    function show(i: number) {
      i = ((i % N) + N) % N;
      if (i === current) return;
      slides[current].style.opacity = '0';
      slides[i].style.opacity = '1';
      thumbs.forEach((t) =>
        t.setAttribute('data-unidade-thumb', Number(t.dataset.unidadeIdx) === i ? 'active' : '')
      );
      current = i;
    }

    thumbs.forEach((thumb) =>
      thumb.addEventListener('click', () => show(Number(thumb.dataset.unidadeIdx)))
    );

    // Swipe/drag to change slide (mobile). Detects horizontal intent so the
    // page can still scroll vertically; the image does not follow the finger —
    // on release it fades to the next/previous slide.
    const THRESHOLD = 40;
    let downX = 0;
    let downY = 0;
    let tracking = false;
    let horizontal = false;
    stage.style.touchAction = 'pan-y';

    stage.addEventListener('pointerdown', (e) => {
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      if ((e.target as HTMLElement).closest('[data-unidade-idx]')) return; // thumbnail
      tracking = true;
      horizontal = false;
      downX = e.clientX;
      downY = e.clientY;
    });
    stage.addEventListener('pointermove', (e) => {
      if (!tracking || horizontal) return;
      const dx = e.clientX - downX;
      const dy = e.clientY - downY;
      if (Math.abs(dx) < 8 && Math.abs(dy) < 8) return;
      if (Math.abs(dx) <= Math.abs(dy)) {
        tracking = false; // vertical gesture → let the page scroll
        return;
      }
      horizontal = true;
    });
    const end = (e: PointerEvent) => {
      if (!tracking) return;
      tracking = false;
      if (!horizontal) return;
      horizontal = false;
      const dx = e.clientX - downX;
      if (dx <= -THRESHOLD) show(current + 1);
      else if (dx >= THRESHOLD) show(current - 1);
    };
    stage.addEventListener('pointerup', end);
    stage.addEventListener('pointercancel', end);
  }
</script>
