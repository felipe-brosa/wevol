---
// Main links render as the vertical list (with dividers) inside the overlay menu.
const mainLinks = ['Home', 'Sobre', 'Tecnologias', 'Experiência', 'Unidades', 'Blog'];
// Footer links sit in a separate row at the bottom of the overlay menu.
const footerLinks = ['Contato', 'Seja um franqueado'];
// Desktop shows every link in a single row.
const desktopLinks = [...mainLinks, ...footerLinks];
const activeLabel = 'Home';
---

<header data-header class="fixed inset-x-0 top-0 z-50">
  <div class="wv-container">
    <div data-bar class="wv-bar">
      <a href="#" class="wv-logo wv-link" aria-label="WEVOL — página inicial">
        <img data-logo-full src="icons/wevol-logo-light.svg" alt="WEVOL" class="wv-logo-full" />
        <img data-logo-stamp src="icons/wevol-stamp-light.svg" alt="" aria-hidden="true" class="wv-logo-stamp" />
      </a>

      <nav data-nav class="hidden items-center gap-4 text-base whitespace-nowrap xl:flex" aria-label="Navegação principal">
        {desktopLinks.map((label) => (
          <a
            href="#"
            aria-current={label === activeLabel ? 'page' : undefined}
            class:list={['wv-link', label === activeLabel ? 'text-wevol-grad-1' : 'text-wevol-off-white']}
          >
            {label}
          </a>
        ))}
      </nav>

      <button
        type="button"
        class="wv-link flex items-center gap-2 p-2 text-base text-wevol-off-white xl:hidden"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="wv-menu"
        data-menu-toggle
      >
        <span>Menu</span>
        <span class="flex flex-col gap-1">
          <span class="block h-0.5 w-5 bg-wevol-off-white"></span>
          <span class="block h-0.5 w-5 bg-wevol-off-white"></span>
          <span class="block h-0.5 w-5 bg-wevol-off-white"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Overlay menu (tablet / mobile) -->
<div
  id="wv-menu"
  data-menu
  class="fixed inset-0 z-[60] hidden items-center justify-center xl:hidden"
  aria-hidden="true"
>
  <div data-menu-panel class="wv-menu-panel">
    <button type="button" class="wv-menu-close wv-link" aria-label="Fechar menu" data-menu-close>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="size-6 md:size-8">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <div class="flex w-full flex-1 flex-col items-center justify-center gap-16 md:gap-24">
      <img
        data-menu-logo
        src="icons/wevol-logo-light.svg"
        alt="WEVOL"
        class="h-[51px] w-[200px] shrink-0"
      />

      <ul class="flex w-full flex-col items-start gap-4">
        {mainLinks.map((label, i) => (
          <li class="w-full">
            <a
              href="#"
              data-menu-item
              aria-current={label === activeLabel ? 'page' : undefined}
              class:list={[
                'wv-link wv-title block leading-[1.25] text-2xl md:text-4xl',
                label === activeLabel ? 'text-wevol-grad-1' : 'text-wevol-off-white',
              ]}
            >
              {label}
            </a>
            {i < mainLinks.length - 1 && <div class="mt-4 h-0.5 w-full bg-wevol-line"></div>}
          </li>
        ))}
      </ul>

      <div class="flex w-full items-center justify-between text-base font-medium text-wevol-off-white md:justify-center md:gap-24 md:text-2xl">
        {footerLinks.map((label) => (
          <a href="#" data-menu-item class="wv-link whitespace-nowrap">{label}</a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  /* Header slides out of view on scroll-down, back in on scroll-up */
  [data-header] {
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  [data-header].is-hidden {
    transform: translateY(-140%);
    pointer-events: none;
  }

  /* ── Desktop bar: morphs into a compact centered pill on scroll ──────────
     Only max-width and the horizontal padding animate, so the items glide all
     the way to the centre and the background hugs their current extent at every
     instant. The vertical size (margin-top + padding-block) switches instantly
     and cancels out, so the pill keeps its final height from the start and the
     content never jumps vertically. */
  .wv-bar {
    margin-inline: auto;
    margin-top: 12px;
    display: flex;
    width: 100%;
    max-width: var(--bar-expanded, 1608px);
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 12px 0;
    background-color: transparent;
    transition:
      max-width 0.8s cubic-bezier(0.33, 1, 0.68, 1),
      padding-left 0.8s cubic-bezier(0.33, 1, 0.68, 1),
      padding-right 0.8s cubic-bezier(0.33, 1, 0.68, 1),
      background-color 0.4s ease,
      border-color 0.4s ease,
      backdrop-filter 0.4s ease;
  }

  .wv-logo {
    position: relative;
    display: block;
    height: 32px;
    width: 92px;
    flex-shrink: 0;
    /* Width swaps instantly (the logo "transforms" fast); its position is
       animated by the surrounding bar shrinking toward the centre. */
  }
  .wv-logo img {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    transition: opacity 0.2s ease;
  }
  .wv-logo-full {
    height: 23px;
    width: 92px;
  }
  .wv-logo-stamp {
    height: 32px;
    width: 32px;
    opacity: 0;
  }

  /* Desktop (≥1280): the full pill morph */
  @media (min-width: 1280px) {
    [data-header].is-scrolled .wv-bar {
      max-width: var(--bar-compact, 820px);
      margin-top: 16px;
      padding: 8px 24px 8px 12px;
      background-color: color-mix(in srgb, var(--color-wevol-black) 90%, transparent);
      border-color: var(--color-wevol-line);
      backdrop-filter: blur(8px);
    }
    [data-header].is-scrolled .wv-logo {
      width: 32px;
    }
    [data-header].is-scrolled .wv-logo-full {
      opacity: 0;
    }
    [data-header].is-scrolled .wv-logo-stamp {
      opacity: 1;
    }
  }

  /* Tablet / mobile (<1280): subtle solid background on scroll for legibility */
  @media (max-width: 1279px) {
    [data-header].is-scrolled .wv-bar {
      background-color: color-mix(in srgb, var(--color-wevol-black) 92%, transparent);
      backdrop-filter: blur(8px);
    }
  }

  /* ── Overlay menu (tablet / mobile) ─────────────────────────────────────── */
  /* Container padding sets the gap between the panel and the screen edges —
     larger on top so the panel clears the browser chrome. */
  [data-menu] {
    padding: 44px 16px 24px;
  }
  @media (min-width: 768px) {
    [data-menu] {
      padding: 56px 40px 40px;
    }
  }

  .wv-menu-panel {
    position: relative;
    display: flex;
    width: 100%;
    height: 100%;
    max-width: 1279px;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    border-radius: 16px;
    background-color: var(--color-wevol-black);
    padding: 48px 32px;
    transform-origin: center;
    will-change: transform, opacity;
  }

  .wv-menu-close {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: var(--color-wevol-off-white);
  }
  @media (min-width: 768px) {
    .wv-menu-close {
      width: 72px;
      height: 72px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wv-bar,
    .wv-logo,
    .wv-logo img {
      transition: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Desktop pill: measure the compact width + toggle on scroll ───────────
  const header = document.querySelector<HTMLElement>('[data-header]');
  const bar = header?.querySelector<HTMLElement>('[data-bar]');
  const nav = bar?.querySelector<HTMLElement>('[data-nav]');

  function measureBar() {
    if (!bar) return;
    // Expanded max-width = wv-container content width, so the transition has a
    // real length to animate from (transitioning from `none` would teleport).
    const expanded = Math.min(window.innerWidth, 1672) - 64;
    bar.style.setProperty('--bar-expanded', `${expanded}px`);
    if (nav && window.innerWidth >= 1280) {
      // stamp (32) + gap (16) + nav content + padding (12 + 24) + border (2)
      const compact = 32 + 16 + nav.scrollWidth + 12 + 24 + 2;
      bar.style.setProperty('--bar-compact', `${compact}px`);
    }
  }

  // Distance (px) the user must scroll down — measured from each direction
  // change — before the bar may hide. Scrolling up brings it straight back.
  const HIDE_AFTER = 280;
  // Once the bar appears/transforms it stays put for at least this long — even
  // while scrolling down — before it is allowed to hide again.
  const DWELL_MS = 2000;
  const MORPH_MS = 800; // desktop pill morph duration
  const SHOW_MS = 450; // slide-back-in duration
  let lastY = window.scrollY;
  let anchorY = window.scrollY;
  let goingDown = false;
  let wasScrolled = false;
  let hideLockedUntil = 0;

  function onScroll() {
    if (!header) return;
    const y = window.scrollY;
    const delta = y - lastY;
    const now = performance.now();
    const isDesktop = window.innerWidth >= 1280;

    // Compact pill (desktop) / solid background (tablet-mobile) forms just off
    // the top. When it first forms, lock it visible through entry + dwell.
    const nowScrolled = y > 16;
    if (nowScrolled && !wasScrolled) {
      hideLockedUntil = now + (isDesktop ? MORPH_MS : 0) + DWELL_MS;
    }
    wasScrolled = nowScrolled;
    header.classList.toggle('is-scrolled', nowScrolled);

    // At the very top the bar is always shown (expanded state)
    if (!nowScrolled) {
      header.classList.remove('is-hidden');
      lastY = y;
      return;
    }

    // Hide on scroll-down / reappear on scroll-up, respecting the dwell lock
    if (Math.abs(delta) > 3) {
      const nowDown = delta > 0;
      if (nowDown !== goingDown) {
        goingDown = nowDown;
        anchorY = y; // reset the travel anchor on each direction change
      }
      if (goingDown) {
        if (y - anchorY > HIDE_AFTER && y > 80 && now >= hideLockedUntil) {
          header.classList.add('is-hidden');
        }
      } else if (header.classList.contains('is-hidden')) {
        // reappeared on scroll-up → lock it visible again before it may hide
        header.classList.remove('is-hidden');
        hideLockedUntil = now + SHOW_MS + DWELL_MS;
      }
    }

    lastY = y;
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', measureBar);
  onScroll();
  if (document.fonts?.ready) {
    document.fonts.ready.then(measureBar);
  } else {
    measureBar();
  }

  // ── Overlay menu open / close ────────────────────────────────────────────
  const toggle = document.querySelector<HTMLElement>('[data-menu-toggle]');
  const closeBtn = document.querySelector<HTMLElement>('[data-menu-close]');
  const menu = document.querySelector<HTMLElement>('[data-menu]');
  const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
  const logo = document.querySelector<HTMLElement>('[data-menu-logo]');
  const items = gsap.utils.toArray<HTMLElement>('[data-menu-item]');

  let isOpen = false;
  let tl: gsap.core.Timeline | null = null;

  function openMenu() {
    if (isOpen || !menu) return;
    isOpen = true;
    menu.classList.remove('hidden');
    menu.classList.add('flex');
    menu.setAttribute('aria-hidden', 'false');
    document.body.classList.add('wv-menu-open');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Fechar menu');

    if (reduceMotion) {
      gsap.set([panel, logo, ...items], { opacity: 1, y: 0, scale: 1 });
      return;
    }

    // Total ~600ms: panel grows → logo slides in → items stagger in.
    tl?.kill();
    tl = gsap.timeline();
    tl.fromTo(panel, { scale: 0.9, opacity: 0 }, { scale: 1, opacity: 1, duration: 0.3, ease: 'power3.out' }, 0)
      .fromTo(logo, { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 0.3, ease: 'power3.out' }, 0.1)
      .fromTo(
        items,
        { y: 16, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.3, ease: 'power3.out', stagger: 0.035 },
        0.18
      );
  }

  function closeMenu() {
    if (!isOpen || !menu) return;
    isOpen = false;
    menu.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Abrir menu');

    const done = () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      document.body.classList.remove('wv-menu-open');
    };

    if (reduceMotion) {
      done();
      return;
    }

    tl?.kill();
    tl = gsap.timeline({ onComplete: done });
    tl.to([logo, ...items], { opacity: 0, y: 8, duration: 0.15, ease: 'power2.in' }, 0)
      .to(panel, { scale: 0.95, opacity: 0, duration: 0.2, ease: 'power2.in' }, 0.05);
  }

  toggle?.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()));
  closeBtn?.addEventListener('click', closeMenu);
  // Clicking the exposed site area around the panel closes the menu.
  menu?.addEventListener('click', (e) => {
    if (e.target === menu) closeMenu();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });
</script>
