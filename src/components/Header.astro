---
// Main links render as the vertical list (with dividers) inside the overlay menu.
const mainLinks = ['Home', 'Sobre', 'Tecnologias', 'Experiência', 'Unidades', 'Blog'];
// Footer links sit in a separate row at the bottom of the overlay menu.
const footerLinks = ['Contato', 'Seja um franqueado'];
// Desktop shows every link in a single row.
const desktopLinks = [...mainLinks, ...footerLinks];
const activeLabel = 'Home';
---

<header data-header class="fixed inset-x-0 top-0 z-50">
  <div class="wv-container">
    <div data-bar class="wv-bar">
      <a href="#" class="wv-logo wv-link" aria-label="WEVOL — página inicial">
        <img data-logo-full src="icons/wevol-logo-light.svg" alt="WEVOL" class="wv-logo-full" />
        <img data-logo-stamp src="icons/wevol-stamp-light.svg" alt="" aria-hidden="true" class="wv-logo-stamp" />
      </a>

      <nav data-nav class="hidden items-center gap-4 text-base whitespace-nowrap lg:flex" aria-label="Navegação principal">
        {desktopLinks.map((label) => (
          <a
            href="#"
            class:list={['wv-link', label === activeLabel ? 'text-wevol-grad-1' : 'text-wevol-off-white']}
          >
            {label}
          </a>
        ))}
      </nav>

      <button
        type="button"
        class="wv-link flex flex-col gap-1.5 p-2 lg:hidden"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="wv-menu"
        data-menu-toggle
      >
        <span class="block h-0.5 w-6 bg-wevol-off-white"></span>
        <span class="block h-0.5 w-6 bg-wevol-off-white"></span>
        <span class="block h-0.5 w-6 bg-wevol-off-white"></span>
      </button>
    </div>
  </div>
</header>

<!-- Overlay menu (tablet / mobile) -->
<div
  id="wv-menu"
  data-menu
  class="fixed inset-0 z-[60] hidden items-center justify-center lg:hidden"
  aria-hidden="true"
>
  <div data-menu-panel class="wv-menu-panel">
    <button type="button" class="wv-menu-close wv-link" aria-label="Fechar menu" data-menu-close>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="size-6 sm:size-8">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <div class="flex w-full flex-1 flex-col items-center justify-center gap-16 sm:gap-24">
      <img
        data-menu-logo
        src="icons/wevol-logo-light.svg"
        alt="WEVOL"
        class="h-[51px] w-[200px] shrink-0"
      />

      <ul class="flex w-full flex-col items-start gap-4">
        {mainLinks.map((label, i) => (
          <li class="w-full">
            <a
              href="#"
              data-menu-item
              class:list={[
                'wv-link wv-title block leading-[1.25] text-2xl sm:text-4xl',
                label === activeLabel ? 'text-wevol-grad-1' : 'text-wevol-off-white',
              ]}
            >
              {label}
            </a>
            {i < mainLinks.length - 1 && <div class="mt-4 h-0.5 w-full bg-wevol-line"></div>}
          </li>
        ))}
      </ul>

      <div class="flex w-full items-center justify-between text-base font-medium text-wevol-off-white sm:justify-center sm:gap-24 sm:text-2xl">
        {footerLinks.map((label) => (
          <a href="#" data-menu-item class="wv-link whitespace-nowrap">{label}</a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  /* ── Desktop bar: morphs into a compact centered pill on scroll ────────── */
  .wv-bar {
    margin-inline: auto;
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 25px 0;
    background-color: transparent;
    transition:
      max-width 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      padding 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      background-color 0.4s ease,
      border-color 0.4s ease,
      backdrop-filter 0.4s ease;
  }

  .wv-logo {
    position: relative;
    display: block;
    height: 32px;
    width: 92px;
    flex-shrink: 0;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .wv-logo img {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    transition: opacity 0.3s ease;
  }
  .wv-logo-full {
    height: 23px;
    width: 92px;
  }
  .wv-logo-stamp {
    height: 32px;
    width: 32px;
    opacity: 0;
  }

  /* Desktop: the full pill morph */
  @media (min-width: 1024px) {
    [data-header].is-scrolled .wv-bar {
      max-width: var(--bar-compact, 820px);
      padding: 8px 24px 8px 12px;
      background-color: color-mix(in srgb, var(--color-wevol-black) 90%, transparent);
      border-color: var(--color-wevol-line);
      backdrop-filter: blur(8px);
    }
    [data-header].is-scrolled .wv-logo {
      width: 32px;
    }
    [data-header].is-scrolled .wv-logo-full {
      opacity: 0;
    }
    [data-header].is-scrolled .wv-logo-stamp {
      opacity: 1;
    }
  }

  /* Tablet / mobile: subtle solid background on scroll for legibility */
  @media (max-width: 1023px) {
    [data-header].is-scrolled .wv-bar {
      padding-block: 12px;
      background-color: color-mix(in srgb, var(--color-wevol-black) 92%, transparent);
      backdrop-filter: blur(8px);
    }
  }

  /* ── Overlay menu panel ────────────────────────────────────────────────── */
  .wv-menu-panel {
    position: relative;
    display: flex;
    height: 95vh;
    width: 95vw;
    max-width: 1279px;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    border-radius: 16px;
    background-color: var(--color-wevol-black);
    padding: 48px 32px;
    transform-origin: center;
    will-change: transform, opacity;
  }

  .wv-menu-close {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: var(--color-wevol-off-white);
  }
  @media (min-width: 640px) {
    .wv-menu-close {
      width: 72px;
      height: 72px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wv-bar,
    .wv-logo,
    .wv-logo img {
      transition: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Desktop pill: measure the compact width + toggle on scroll ───────────
  const header = document.querySelector<HTMLElement>('[data-header]');
  const bar = header?.querySelector<HTMLElement>('[data-bar]');
  const nav = bar?.querySelector<HTMLElement>('[data-nav]');

  function measureCompact() {
    if (!bar || !nav || window.innerWidth < 1024) return;
    // stamp (32) + gap (16) + nav content + padding (12 + 24) + border (2)
    const compact = 32 + 16 + nav.scrollWidth + 12 + 24 + 2;
    bar.style.setProperty('--bar-compact', `${compact}px`);
  }

  function onScroll() {
    header?.classList.toggle('is-scrolled', window.scrollY > 32);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', measureCompact);
  onScroll();
  if (document.fonts?.ready) {
    document.fonts.ready.then(measureCompact);
  } else {
    measureCompact();
  }

  // ── Overlay menu open / close ────────────────────────────────────────────
  const toggle = document.querySelector<HTMLElement>('[data-menu-toggle]');
  const closeBtn = document.querySelector<HTMLElement>('[data-menu-close]');
  const menu = document.querySelector<HTMLElement>('[data-menu]');
  const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
  const logo = document.querySelector<HTMLElement>('[data-menu-logo]');
  const items = gsap.utils.toArray<HTMLElement>('[data-menu-item]');

  let isOpen = false;
  let tl: gsap.core.Timeline | null = null;

  function openMenu() {
    if (isOpen || !menu) return;
    isOpen = true;
    menu.classList.remove('hidden');
    menu.classList.add('flex');
    menu.setAttribute('aria-hidden', 'false');
    document.body.classList.add('wv-menu-open');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Fechar menu');

    if (reduceMotion) {
      gsap.set([panel, logo, ...items], { opacity: 1, y: 0, scale: 1 });
      return;
    }

    // Total ~600ms: panel grows → logo slides in → items stagger in.
    tl?.kill();
    tl = gsap.timeline();
    tl.fromTo(panel, { scale: 0.9, opacity: 0 }, { scale: 1, opacity: 1, duration: 0.3, ease: 'power3.out' }, 0)
      .fromTo(logo, { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 0.3, ease: 'power3.out' }, 0.1)
      .fromTo(
        items,
        { y: 16, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.3, ease: 'power3.out', stagger: 0.035 },
        0.18
      );
  }

  function closeMenu() {
    if (!isOpen || !menu) return;
    isOpen = false;
    menu.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Abrir menu');

    const done = () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      document.body.classList.remove('wv-menu-open');
    };

    if (reduceMotion) {
      done();
      return;
    }

    tl?.kill();
    tl = gsap.timeline({ onComplete: done });
    tl.to([logo, ...items], { opacity: 0, y: 8, duration: 0.15, ease: 'power2.in' }, 0)
      .to(panel, { scale: 0.95, opacity: 0, duration: 0.2, ease: 'power2.in' }, 0.05);
  }

  toggle?.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()));
  closeBtn?.addEventListener('click', closeMenu);
  // Clicking the exposed site area around the panel closes the menu.
  menu?.addEventListener('click', (e) => {
    if (e.target === menu) closeMenu();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });
</script>
