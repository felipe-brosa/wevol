---
// "Histórias reais. Evoluções reais." — coverflow carousel of story videos.
// Center card is largest at full opacity; side cards shrink + fade with distance.
// Desktop shows 5 cards (±2), tablet/mobile show 3 (±1). Videos are the shared
// placeholder until the real ones arrive; each card keeps a distinct poster.
const stories = [
  { poster: 'images/historia-1.png' },
  { poster: 'images/historia-2.png' },
  { poster: 'images/historia-3.png' },
  { poster: 'images/historia-4.png' },
  { poster: 'images/historia-5.png' },
  { poster: 'images/historia-6.png' },
];
const VIDEO = 'videos/hero-placeholder.webm';
---

<section
  class="relative overflow-hidden bg-wevol-black py-24"
  style="--hist-cw: clamp(260px, 150px + 27.3vw, 360px)"
  data-historias
>
  <h2
    class="wv-title wv-ftype [--fs-min:36] [--fs-max:60] mx-auto max-w-[806px] px-8 text-center leading-[1.25] text-wevol-off-white xl:max-w-none xl:whitespace-nowrap"
    data-reveal="words"
  >
    Histórias reais. Evoluções reais.
  </h2>

  <div
    class="relative mt-16 w-full md:mt-20"
    style="height: calc(var(--hist-cw) * 581 / 360)"
    data-hist-track
  >
    {stories.map((story, i) => (
      <button
        type="button"
        class="hist-card absolute left-1/2 top-1/2 aspect-[360/581] w-[var(--hist-cw)] cursor-pointer overflow-hidden rounded-lg"
        data-hist-card={i}
        aria-label={`História ${i + 1}`}
      >
        <video
          class="pointer-events-none size-full object-cover"
          poster={story.poster}
          muted
          loop
          playsinline
          preload="none"
        >
          <source src={VIDEO} type="video/webm" />
        </video>
        {/* center-only hover affordance: dim + play button */}
        <span class="hist-overlay pointer-events-none absolute inset-0 grid place-items-center bg-black/30 opacity-0">
          <span class="grid size-16 place-items-center rounded-full border border-wevol-off-white/70 bg-black/20 backdrop-blur-sm">
            <svg width="22" height="26" viewBox="0 0 22 26" fill="none" aria-hidden="true" class="hist-icon-play translate-x-0.5">
              <path d="M0 1.5 20 13 0 24.5V1.5Z" fill="currentColor" class="text-wevol-off-white" />
            </svg>
            <svg width="20" height="24" viewBox="0 0 20 24" fill="currentColor" aria-hidden="true" class="hist-icon-pause hidden text-wevol-off-white">
              <rect x="2" y="1" width="5" height="22" rx="1" />
              <rect x="13" y="1" width="5" height="22" rx="1" />
            </svg>
          </span>
        </span>
      </button>
    ))}
  </div>
</section>

<style>
  .hist-card {
    transform: translate(-50%, -50%);
    transform-origin: center;
    will-change: transform, opacity;
    transition:
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.55s ease;
  }
  .hist-card:focus-visible {
    outline: 2px solid var(--color-wevol-orange);
    outline-offset: 3px;
  }
  .hist-overlay {
    transition: opacity 0.3s ease;
  }
  /* Only the centered card reveals the dim + play control on hover/focus */
  .hist-card.is-center:hover .hist-overlay,
  .hist-card.is-center:focus-visible .hist-overlay {
    opacity: 1;
  }
  .hist-card.is-playing .hist-icon-play {
    display: none;
  }
  .hist-card.is-playing .hist-icon-pause {
    display: block;
  }
  /* draggable: vertical scroll stays native, horizontal is handled in JS */
  [data-hist-track] {
    touch-action: pan-y;
  }
  /* while dragging, cards follow the pointer with no easing (instant) */
  [data-hist-track].is-dragging .hist-card {
    transition: none;
  }
  [data-hist-track].is-dragging,
  [data-hist-track].is-dragging .hist-card {
    cursor: grabbing;
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-historias]');
  if (root) {
    const track = root.querySelector<HTMLElement>('[data-hist-track]')!;
    const cards = [...root.querySelectorAll<HTMLButtonElement>('[data-hist-card]')];
    const N = cards.length;
    const SCALE = [1, 0.944, 0.889];
    const OPACITY = [1, 0.6, 0.25];
    const GAP = 12; // constant edge-to-edge gap kept equal between all neighbours
    let busy = false;

    // Desktop (≥1280) shows two cards per side, tablet/mobile one.
    const range = () => (window.innerWidth >= 1280 ? 2 : 1);

    // Continuous slot of every card (…-2 -1 0 1 2 3…). Unlike a wrapped offset,
    // this preserves motion direction: a card leaving on the left slides to a more
    // negative slot, then — while off-screen — is recycled to the far right so it
    // can re-enter. That recycle is the only teleport and it is always invisible.
    const curPos = cards.map((_, i) => {
      let o = ((i % N) + N) % N;
      if (o > N / 2) o -= N;
      return o;
    });

    const lerp = (a: number, b: number, f: number) => a + (b - a) * f;
    const scaleAt = (k: number) => SCALE[Math.abs(k)] ?? 0.85;
    // Continuous scale/opacity so a fractional (dragged) offset interpolates.
    const scaleFor = (abs: number) => {
      const i = Math.floor(abs);
      return lerp(SCALE[i] ?? 0.85, SCALE[i + 1] ?? 0.85, abs - i);
    };
    const opacityFor = (abs: number, r: number) => {
      if (abs >= r + 1) return 0;
      const i = Math.floor(abs);
      return lerp(OPACITY[i] ?? 0, OPACITY[i + 1] ?? 0, abs - i);
    };
    // Distance between the centres of slot k and k+1 = half of each neighbouring
    // card (at its own scale) + the fixed gap. Summing these keeps every visible
    // gap identical — the old constant step bunched the middle because the scaled
    // side cards are narrower, so their edges drifted further apart.
    const segLen = (k: number) => {
      const w = cards[0].offsetWidth;
      return (w / 2) * scaleAt(k) + GAP + (w / 2) * scaleAt(k + 1);
    };
    const slotX = (off: number) => {
      const sign = Math.sign(off);
      const abs = Math.abs(off);
      const whole = Math.floor(abs);
      let x = 0;
      for (let k = 0; k < whole; k++) x += segLen(k);
      x += segLen(whole) * (abs - whole);
      return sign * x;
    };

    function render(teleport?: Set<number>, drag = 0) {
      const r = range();
      cards.forEach((card, i) => {
        const off = curPos[i] + drag;
        const abs = Math.abs(off);
        if (teleport?.has(i)) card.style.transition = 'none';
        card.style.transform = `translate(-50%, -50%) translateX(${slotX(off)}px) scale(${scaleFor(abs)})`;
        card.style.opacity = String(opacityFor(abs, r));
        card.style.zIndex = String(10 - Math.round(abs));
        card.style.pointerEvents = abs <= r ? 'auto' : 'none';
        const centered = !drag && abs < 0.5;
        card.classList.toggle('is-center', centered);
        card.setAttribute('aria-hidden', centered ? 'false' : 'true');
        if (!centered) {
          const v = card.querySelector('video');
          if (v && !v.paused) v.pause();
          card.classList.remove('is-playing');
        }
      });
      // Commit any teleport instantly, then restore transitions for next moves.
      if (teleport?.size) {
        void track.offsetWidth; // reflow
        teleport.forEach((i) => (cards[i].style.transition = ''));
      }
    }

    // Shift the whole ribbon one slot. dir>0 moves it left ("next"), dir<0 right.
    function shift(dir: number) {
      const r = range();
      // Recycle the spare that has fallen off the far side to the incoming edge,
      // while it is off-screen, so it re-enters instead of sliding across.
      const teleport = new Set<number>();
      cards.forEach((_, i) => {
        if (dir > 0 && curPos[i] <= -(r + 1)) {
          curPos[i] += N;
          teleport.add(i);
        } else if (dir < 0 && curPos[i] >= r + 1) {
          curPos[i] -= N;
          teleport.add(i);
        }
      });
      if (teleport.size) render(teleport);
      cards.forEach((_, i) => (curPos[i] -= dir));
      render();
    }

    // Bring card i to the centre, one slot at a time (nothing jumps across).
    function goTo(i: number): boolean {
      const off = curPos[i];
      if (off === 0) return false; // already centred
      if (busy) return true;
      busy = true;
      const dir = off > 0 ? 1 : -1;
      let remaining = Math.abs(off);
      // Wait a touch longer than the 0.55s slide so the exiting card is fully
      // hidden before the next step recycles it (keeps the recycle invisible).
      const tick = () => {
        shift(dir);
        if (--remaining > 0) setTimeout(tick, 580);
        else busy = false;
      };
      tick();
      return true;
    }

    // --- drag / swipe state (shared with the click guard) ---
    const SETTLE_FRACTION = 0.18; // portion of a slot to drag before it advances
    let downX = 0;
    let downY = 0;
    let tracking = false;
    let horizontal = false;
    let dragged = false;
    let dragFrac = 0;
    const stepPx = () => segLen(0) || 1;

    cards.forEach((card, i) => {
      card.addEventListener('click', () => {
        if (dragged) {
          dragged = false; // a drag just ended → swallow the synthetic click
          return;
        }
        if (goTo(i)) return; // side card (or a move is already in progress)
        // centre card: toggle playback
        const v = card.querySelector('video');
        if (!v) return;
        if (v.paused) {
          v.play().catch(() => {});
          card.classList.add('is-playing');
        } else {
          v.pause();
          card.classList.remove('is-playing');
        }
      });
    });

    // Drag/swipe on the ribbon: follow the pointer, then snap to prev/next.
    // Works on desktop, tablet and mobile; horizontal intent is detected first
    // so vertical page scroll is preserved.
    track.addEventListener('pointerdown', (e) => {
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      if (busy) return;
      tracking = true;
      horizontal = false;
      dragged = false;
      dragFrac = 0;
      downX = e.clientX;
      downY = e.clientY;
      document.body.style.userSelect = 'none'; // stop grab-selecting on desktop
    });
    track.addEventListener('pointermove', (e) => {
      if (!tracking) return;
      const dx = e.clientX - downX;
      const dy = e.clientY - downY;
      if (!horizontal) {
        if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return;
        if (Math.abs(dx) <= Math.abs(dy)) {
          tracking = false; // vertical gesture → let the page scroll
          document.body.style.userSelect = '';
          return;
        }
        horizontal = true;
        dragged = true;
        window.getSelection?.()?.removeAllRanges();
        track.classList.add('is-dragging');
        try { track.setPointerCapture(e.pointerId); } catch {}
      }
      dragFrac = dx / stepPx();
      render(undefined, dragFrac);
    });
    const endDrag = (e: PointerEvent) => {
      document.body.style.userSelect = '';
      if (!tracking) return;
      tracking = false;
      if (!horizontal) return;
      horizontal = false;
      track.classList.remove('is-dragging');
      try { track.releasePointerCapture(e.pointerId); } catch {}
      let settle = 0;
      if (dragFrac >= SETTLE_FRACTION) settle = 1;
      else if (dragFrac <= -SETTLE_FRACTION) settle = -1;
      if (settle === 0) {
        render(); // not far enough → ease back to the current card
        return;
      }
      // The card that should become centre currently sits at off = -settle.
      const target = curPos.findIndex((p) => p === -settle);
      if (target >= 0) goTo(target);
      else render();
    };
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', endDrag);
    track.addEventListener('dragstart', (e) => e.preventDefault());

    const all = () => new Set(cards.map((_, i) => i));
    render(all()); // initial placement, no animation

    let rt: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => render(all()), 100);
    });
  }
</script>
