---
import '@fontsource/instrument-sans/400.css';
import '@fontsource/instrument-sans/500.css';
import '@fontsource/instrument-sans/600.css';
import '@fontsource/instrument-sans/700.css';
import '@fontsource/instrument-serif';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'WEVOL — Evolução da saúde e performance',
  description =
    'Muito mais do que um treino. A WEVOL integra tecnologia, inteligência e acompanhamento personalizado para criar uma experiência única de evolução humana.',
} = Astro.props;

// <base> só resolve URLs relativas como diretório se terminar em "/"
const rawBase = import.meta.env.BASE_URL;
const baseHref = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    {/* base must come first so every relative URL below (and all asset paths)
        resolves against the deploy path — '/' locally, '/repo/' on Pages subpaths */}
    <base href={baseHref} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // marks JS availability so reveal targets can start hidden (no-JS keeps content visible)
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    {/*
      Entry loader — painted immediately (render-blocking global.css) and shown
      only when JS can dismiss it (html.js). The ring is a trim-path tied to the
      hero video load; scripts/animations.ts drives it, then plays the reveal.
    */}
    <div id="wv-loader" aria-hidden="true">
      <div class="wv-loader__inner">
        <svg class="wv-loader__mark" viewBox="0 0 242.3 242.3" fill="none" aria-hidden="true">
          {/* W monogram — fixed in the centre (WEVOL stamp mark, ~0.70 scale) */}
          <g transform="translate(121.15 121.15) scale(0.705) translate(-121.15 -121.15)">
            <path
              d="M190.9,87.3l-27.2,81.8c-1,3.1-4,5.3-7.3,5.3h-25.9c-4.3,0-7.6-3.5-7.6-7.6v-84.5h-4.8l-25.7,77.1c-1,3.1-4,5.3-7.3,5.3h-26.1c-4.3,0-7.6-3.5-7.6-7.6v-69.8h19v65.6h3.9l26.6-79.8c1-3.1,4-5.3,7.3-5.3h25.9c4.3,0,7.6,3.5,7.6,7.6v87.3h3.9l25.2-75.3h20.2-.1c0-.1,0-.1,0-.1Z"
              fill="#fff6e5"
            />
          </g>
          {/* progress ring — pathLength=1 so dashoffset = 1 − progress; starts at 12 o'clock */}
          <circle
            class="wv-loader__ring"
            cx="121.15"
            cy="121.15"
            r="112"
            fill="none"
            stroke="#fff6e5"
            stroke-width="5"
            stroke-linecap="round"
            pathLength="1"
            transform="rotate(-90 121.15 121.15)"
          ></circle>
        </svg>
        <p class="wv-loader__text wv-title-alt">Carregando sua experiência</p>
      </div>
    </div>
    <script is:inline>
      // Failsafe: never trap the user behind the loader if the JS bundle fails
      // to load/run. The normal path hides it far sooner (video-ready or 5s cap).
      setTimeout(function () {
        var l = document.getElementById('wv-loader');
        if (l && l.style.display !== 'none') {
          l.style.transition = 'opacity .3s';
          l.style.opacity = '0';
          document.documentElement.classList.remove('wv-loading');
          // release the scroll lock (native + Lenis, if it initialised)
          document.documentElement.style.overflow = '';
          if (window.__wvLenis) window.__wvLenis.start();
          setTimeout(function () {
            l.style.display = 'none';
          }, 300);
        }
      }, 8000);
    </script>
    <slot />
  </body>
</html>
